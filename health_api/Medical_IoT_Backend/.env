# MongoDB Connection String (Required)
MONGODB_URI=mongodb://localhost:27017

# JWT Secret Key (Required - Change in production)
SECRET_KEY=super-secret-key-for-development-only

# Blockfrost API Key for Cardano (Required for Anchoring to work)
# Get one from: https://blockfrost.io/ (Make sure it's for Preprod testnet)
BLOCKFROST_PROJECT_ID=preprod...

# Cardano Wallet configuration (Generated by generate_wallet.py)
CARDANO_SKEY_FILE=admin.skey
CARDANO_WALLET_ADDR=addr_test1vrez...
